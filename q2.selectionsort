#include <stdio.h>
#include <stdlib.h>

static void print_array(const int v[], int n) {
    printf("[");
    for (int i = 0; i < n; i++) {
        printf("%d", v[i]);
        if (i < n - 1) printf(", ");
    }
    printf("]");
}

static void swap_int(int *a, int *b) {
    int tmp = *a;
    *a = *b;
    *b = tmp;
}

void selectionSort(int v[], int n){
if( !v || n<=1)
return;
int comparacoes=0;
int trocas=0;

for(int i=0; i<n-1;i++){
    int idx=i;

for(int j=i+1 ;j<n ;j++){
    comparacoes++;

    if(v[j] < v[idx]){
    idx=j;
}
}
     if (idx!=i){
         trocas++;
       swap_int(&v[i],&v[idx]);
}
}    printf("\ntrocas: %d comparacoes:%d\n",trocas,comparacoes);
}

int main() {
    // Casos pedidos
    int v_vazio[]      = {};                 // n = 0 (não use sizeof aqui)
    int v_um[]         = {7};
    int v_ordenado[]   = {1, 2, 3, 4, 5};
    int v_inverso[]    = {5, 4, 3, 2, 1};
    int v_repetidos[]  = {3, 1, 3, 2, 3};
    int n = 5;

    printf("\n\nVETOR VAZIO ORIGINAL:");
    print_array(v_vazio,0);
    selectionSort(v_vazio,0);
    printf("\nVETOR VAZIO ORDENADO\n");
    print_array(v_vazio,0);

     printf("\n\nVETOR UNICO ORIGINAL:");
    print_array(v_um,1);
    selectionSort(v_um,1);
    printf("\nVETOR UNICO ORDENADO\n");
    print_array(v_um,1);

    printf("\n\nVETOR ORDENADO ORIGINAL:");
    print_array(v_ordenado,n);
    selectionSort(v_ordenado,n);
    printf("VETOR ORDENADO DEPOIS\n");
    print_array(v_ordenado,n);

    printf("\n\nVETOR INVERSO ORIGINAL:");
    print_array(v_inverso,n);
    selectionSort(v_inverso,n);
    printf("VETOR INVERSO DEPOIS\n");
    print_array(v_inverso,n);

    printf("\n\nVETOR REPETIDOS ORIGINAL:");
    print_array(v_repetidos,n);
    selectionSort(v_repetidos,n);
    printf("VETOR REPETIDOS DEPOIS\n");
    print_array(v_repetidos,n);


    return 0;
}
